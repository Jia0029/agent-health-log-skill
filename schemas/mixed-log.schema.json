{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/agent-health-log/schemas/mixed-log.schema.json",
  "title": "Mixed Meal And Workout Log",
  "type": "object",
  "$comment": "additionalProperties is false at the root. Nested meal_log and workout_log allow only the MVP fields needed by CSV writers.",
  "additionalProperties": false,
  "required": ["type", "date", "meal_log", "workout_log", "raw_text", "needs_follow_up"],
  "properties": {
    "type": {
      "type": "string",
      "enum": ["mixed_log"]
    },
    "date": {
      "$ref": "#/$defs/flexible_date"
    },
    "meal_log": {
      "$ref": "#/$defs/meal_log_inner"
    },
    "workout_log": {
      "$ref": "#/$defs/workout_log_inner"
    },
    "raw_text": {
      "type": "string"
    },
    "needs_follow_up": {
      "type": "boolean"
    },
    "follow_up_questions": {
      "type": "array",
      "items": {"type": "string"}
    }
  },
  "$defs": {
    "flexible_date": {
      "type": "string",
      "anyOf": [
        {"format": "date"},
        {"enum": ["today", "yesterday"]}
      ]
    },
    "confidence": {
      "type": "string",
      "enum": ["high", "medium", "low"]
    },
    "nutrition_estimate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["calories_kcal", "protein_g", "carbs_g", "fat_g", "confidence"],
      "properties": {
        "calories_kcal": {"type": ["number", "null"]},
        "protein_g": {"type": ["number", "null"]},
        "carbs_g": {"type": ["number", "null"]},
        "fat_g": {"type": ["number", "null"]},
        "confidence": {"$ref": "#/$defs/confidence"}
      }
    },
    "food_item": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "display_name", "quantity", "nutrition_estimate"],
      "properties": {
        "name": {"type": "string"},
        "display_name": {"type": "string"},
        "quantity": {"type": ["string", "null"]},
        "nutrition_estimate": {"$ref": "#/$defs/nutrition_estimate"},
        "tags": {
          "type": "array",
          "items": {"type": "string"}
        }
      }
    },
    "meal": {
      "type": "object",
      "additionalProperties": false,
      "required": ["meal_time", "items"],
      "properties": {
        "meal_time": {
          "type": "string",
          "enum": ["breakfast", "lunch", "dinner", "snack", "unknown"]
        },
        "items": {
          "type": "array",
          "items": {"$ref": "#/$defs/food_item"}
        }
      }
    },
    "set": {
      "type": "object",
      "additionalProperties": false,
      "required": ["weight_kg", "reps", "set_count"],
      "properties": {
        "weight_kg": {"type": ["number", "null"]},
        "reps": {"type": ["integer", "null"]},
        "set_count": {"type": ["integer", "null"]},
        "duration_minutes": {"type": ["number", "null"]},
        "distance_km": {"type": ["number", "null"]}
      }
    },
    "exercise": {
      "type": "object",
      "additionalProperties": false,
      "required": ["exercise_id", "display_name", "sets", "rpe", "notes"],
      "properties": {
        "exercise_id": {"type": "string"},
        "display_name": {"type": "string"},
        "aliases_seen": {
          "type": "array",
          "items": {"type": "string"}
        },
        "sets": {
          "type": "array",
          "items": {"$ref": "#/$defs/set"}
        },
        "rpe": {"type": ["number", "null"], "minimum": 0, "maximum": 10},
        "notes": {"type": ["string", "null"]}
      }
    },
    "meal_log_inner": {
      "type": "object",
      "additionalProperties": false,
      "required": ["meals"],
      "properties": {
        "meals": {
          "type": "array",
          "items": {"$ref": "#/$defs/meal"}
        }
      }
    },
    "workout_log_inner": {
      "type": "object",
      "additionalProperties": false,
      "required": ["session_type", "focus", "exercises"],
      "properties": {
        "session_type": {
          "type": "string",
          "enum": ["push", "pull", "legs", "cardio", "core", "full_body", "mobility", "unknown"]
        },
        "focus": {"type": ["string", "null"]},
        "exercises": {
          "type": "array",
          "items": {"$ref": "#/$defs/exercise"}
        }
      }
    }
  }
}

